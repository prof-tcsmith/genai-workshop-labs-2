# Copy to .env (gitignored) — the ONLY secret this whole system needs.
OPENAI_API_KEY=sk-your-key-here

# Optional overrides:
# CHAT_MODEL=gpt-4o-mini
# EMBED_MODEL=text-embedding-3-small

# If port 8501 is already taken (e.g. the labs app is running), uncomment —
# docker compose reads this file automatically, on every platform:
# APP_PORT=8502
