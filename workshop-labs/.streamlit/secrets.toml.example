# Copy to .streamlit/secrets.toml (local) or paste into Streamlit Cloud "Secrets".
# Both are OPTIONAL.

# Gate the public app so only workshop attendees can use it (and the shared key).
# Store the SHA-256 HASH of your passphrase, never the passphrase itself. Generate it:
#   printf '%s' 'your-passphrase' | shasum -a 256
# Then set it here (or in Streamlit Cloud Secrets). Leave unset to disable the gate.
# workshop_passphrase_sha256 = "paste-the-64-char-hash-here"

# Optional: pre-load the OpenAI key so attendees don't paste it.
# Per the workshop plan, the default is to leave this UNSET and have attendees
# paste the key Tim hands out. Uncomment only if you want zero-friction entry.
# openai_api_key = "sk-..."
