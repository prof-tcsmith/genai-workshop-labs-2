# Copy to .env (which is gitignored). docker compose reads .env automatically.

# Chat provider: "openai" (default) or "anthropic"
LLM_PROVIDER=openai

# Chat key — set the one matching LLM_PROVIDER:
OPENAI_API_KEY=sk-proj-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Embeddings are ALWAYS OpenAI (Anthropic has no embeddings API), so the RAG
# demos need OPENAI_API_KEY even when LLM_PROVIDER=anthropic.

# OPTIONAL — a real vector DB for the RAG labs (4 & 5). With this set, those
# labs upsert/query a persistent Pinecone index (per-session namespace); without
# it they fall back to an in-RAM store. The rest of the labs never need it.
# PINECONE_API_KEY=pcsk_your-key-here
